# Alpaca Paper Trading API keys (https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Paper trading REST API endpoint
ALPACA_API_BASE_URL=https://paper-api.alpaca.markets/v2

# Market data REST API (bars/quotes use this host; paper keys still apply)
ALPACA_DATA_API_URL=https://data.alpaca.markets

# Alternative variable names (also supported):
# APCA_API_KEY_ID=your_api_key_here
# APCA_API_SECRET_KEY=your_secret_key_here
